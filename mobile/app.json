{
  "expo": {
    "name": "입주해",
    "slug": "ipjuhae",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "ipjuhae",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563EB"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ipjuhae.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "프로필 사진 및 서류 촬영에 카메라가 필요합니다.",
        "NSPhotoLibraryUsageDescription": "프로필 사진 및 서류를 갤러리에서 선택합니다.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563EB"
      },
      "package": "com.ipjuhae.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "서류 촬영을 위해 카메라 접근이 필요합니다."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "프로필 사진을 갤러리에서 선택합니다.",
          "cameraPermission": "프로필 사진을 촬영합니다."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2563EB"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "your-project-id"
      },
      "apiUrl": "https://www.ipjuhae.com/api"
    },
    "platforms": ["ios", "android"]
  }
}
